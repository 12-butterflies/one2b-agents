# Xero MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# From your Xero Developer Portal app
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here

# Populated automatically by "npm run auth"
XERO_TENANT_ID=
XERO_ACCESS_TOKEN=
XERO_REFRESH_TOKEN=
