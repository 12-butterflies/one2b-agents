<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.one2b.apple-mail-sweep</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/jasonpeterstevens/.apple-mail-intel/sweep.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/jasonpeterstevens/.apple-mail-intel</string>

    <key>StartInterval</key>
    <integer>3600</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/apple-mail-sweep-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/apple-mail-sweep-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/jasonpeterstevens</string>
    </dict>
</dict>
</plist>
